---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — BitGuru" description="Get in touch with the BitGuru team. We're here to help you on your crypto learning journey.">
  <div class="pt-32 pb-24">

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-5 sm:px-8 mb-16 md:mb-24">
      <div class="flex flex-col md:flex-row items-end justify-between gap-8">
        <div class="max-w-2xl">
          <span class="text-primary-fixed-dim font-bold tracking-widest text-xs uppercase mb-4 block">Contact us</span>
          <h1 class="text-5xl md:text-7xl font-display font-extrabold tracking-tight text-on-surface leading-tight">
            We're here to help you on your <span class="text-primary-container">journey.</span>
          </h1>
        </div>
        <div class="hidden md:block w-32 h-1 bg-primary-container/20 rounded-full mb-4"></div>
      </div>
    </section>

    <!-- Main Grid -->
    <section class="max-w-7xl mx-auto px-5 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- Contact Form Area (Bento Left) -->
      <div class="lg:col-span-7 bg-surface-container-low p-8 md:p-12 rounded-[2rem] shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-[100px] -mr-32 -mt-32"></div>
        <h2 class="text-3xl font-display font-bold mb-8 text-on-surface">Send a Message</h2>
        <form id="contact-form" class="space-y-6 relative z-10">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant ml-1" for="contact-name">Name</label>
              <input
                id="contact-name"
                name="name"
                required
                class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary-container/20 focus:bg-surface-container-high text-on-surface placeholder:text-outline/50 transition-all"
                placeholder="John Doe"
                type="text"
              />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant ml-1" for="contact-email">Email</label>
              <input
                id="contact-email"
                name="email"
                required
                class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary-container/20 focus:bg-surface-container-high text-on-surface placeholder:text-outline/50 transition-all"
                placeholder="john@example.com"
                type="email"
              />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium text-on-surface-variant ml-1" for="contact-message">Message</label>
            <textarea
              id="contact-message"
              name="message"
              required
              class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary-container/20 focus:bg-surface-container-high text-on-surface placeholder:text-outline/50 transition-all"
              placeholder="How can we assist your trading education?"
              rows="5"
            ></textarea>
          </div>
          <button
            class="w-full md:w-auto gradient-primary text-on-primary-fixed font-display font-bold px-10 py-4 rounded-xl shadow-lg shadow-primary-container/20 hover:opacity-90 active:scale-95 transition-all"
            type="submit"
          >
            Send Message
          </button>
          <div id="contact-success" class="hidden mt-4 p-4 rounded-xl bg-primary-container/10 border border-primary-container/20 text-primary-container font-medium text-center">
            Message sent successfully! We'll get back to you within 24 hours.
          </div>
        </form>
        <script>
          document.getElementById("contact-form")?.addEventListener("submit", (e) => {
            e.preventDefault();
            const form = e.target as HTMLFormElement;
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            btn.textContent = "Sending...";
            btn.disabled = true;
            setTimeout(() => {
              form.reset();
              btn.textContent = "Send Message";
              btn.disabled = false;
              document.getElementById("contact-success")?.classList.remove("hidden");
              setTimeout(() => document.getElementById("contact-success")?.classList.add("hidden"), 5000);
            }, 1500);
          });
        </script>
      </div>

      <!-- Side Cards (Bento Right) -->
      <div class="lg:col-span-5 flex flex-col gap-6">

        <!-- Alternative Support -->
        <div class="bg-surface-container-high p-8 rounded-[2rem] border border-outline-variant/10">
          <h3 class="text-xl font-display font-bold mb-6">Alternative Support</h3>
          <div class="space-y-4">
            <!-- WhatsApp -->
            <a class="flex items-center justify-between p-4 rounded-xl bg-surface-container-lowest group hover:bg-surface-bright transition-colors" href="https://wa.me/15551234567" target="_blank" rel="noopener noreferrer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-green-500/10 text-green-400">
                  <!-- chat icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold">Connect on WhatsApp</p>
                  <p class="text-xs text-on-surface-variant">Instant response</p>
                </div>
              </div>
              <!-- arrow_forward icon -->
              <svg class="text-outline group-hover:text-primary-container transition-colors" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <!-- Telegram -->
            <a class="flex items-center justify-between p-4 rounded-xl bg-surface-container-lowest group hover:bg-surface-bright transition-colors" href="https://t.me/bitguru" target="_blank" rel="noopener noreferrer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary-container/10 text-primary-container">
                  <!-- forum icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    <path d="M8 10h8M8 14h4"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold">Join our Telegram Community</p>
                  <p class="text-xs text-on-surface-variant">24/7 Peer Support</p>
                </div>
              </div>
              <!-- arrow_forward icon -->
              <svg class="text-outline group-hover:text-primary-container transition-colors" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- FAQ Snippet -->
        <div class="bg-surface-container-low p-8 rounded-[2rem] flex-grow">
          <h3 class="text-xl font-display font-bold mb-4">Common questions</h3>
          <div class="space-y-3 mb-6">
            <div class="pb-3 border-b border-outline-variant/10">
              <p class="text-sm font-semibold text-on-surface">How do I access my courses?</p>
            </div>
            <div class="pb-3 border-b border-outline-variant/10">
              <p class="text-sm font-semibold text-on-surface">Do you offer 1-on-1 mentoring?</p>
            </div>
            <div class="pb-3">
              <p class="text-sm font-semibold text-on-surface">Can I get a refund?</p>
            </div>
          </div>
          <a class="text-primary-fixed-dim font-bold text-sm inline-flex items-center gap-2 hover:underline" href="/contact">
            View full FAQ
            <!-- open_in_new icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>

        <!-- Socials -->
        <div class="grid grid-cols-3 gap-4">
          <!-- Brand / X -->
          <a class="bg-surface-container-high aspect-square rounded-2xl flex items-center justify-center hover:bg-surface-bright transition-colors group" href="https://twitter.com/bitguru" target="_blank" rel="noopener noreferrer" aria-label="Follow us on X">
            <svg class="text-on-surface-variant group-hover:text-primary-container transition-colors" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.733-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a class="bg-surface-container-high aspect-square rounded-2xl flex items-center justify-center hover:bg-surface-bright transition-colors group" href="https://instagram.com/bitguru" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram">
            <svg class="text-on-surface-variant group-hover:text-primary-container transition-colors" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <!-- YouTube / Community -->
          <a class="bg-surface-container-high aspect-square rounded-2xl flex items-center justify-center hover:bg-surface-bright transition-colors group" href="https://discord.gg/bitguru" target="_blank" rel="noopener noreferrer" aria-label="Join our community">
            <svg class="text-on-surface-variant group-hover:text-primary-container transition-colors" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </a>
        </div>

      </div>
    </section>

    <!-- Intentional Spacing -->
    <div class="h-24"></div>

    <!-- Trust Indicator / CTA Banner -->
    <section class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="gradient-gold rounded-[2rem] p-12 text-on-secondary flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <h2 class="text-3xl font-display font-black mb-2">Become a Guru.</h2>
          <p class="font-medium opacity-80">Join 50,000+ traders mastering the markets with our premium education.</p>
        </div>
        <a href="/courses" class="bg-surface text-on-surface px-8 py-4 rounded-xl font-display font-bold hover:bg-surface-bright transition-all">
          Explore Our Courses
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
