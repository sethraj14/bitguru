---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Secure Checkout | BitGuru Consultation"
  description="Complete your booking for the 1:1 Expert Consultation and unlock professional-grade crypto insights."
>

  <main class="pt-32 pb-24 px-6 md:px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

      <!-- Left Column: Checkout Form -->
      <div class="lg:col-span-7 space-y-12">

        <section>
          <h1 class="text-4xl md:text-5xl font-display font-extrabold tracking-tight mb-4">
            Complete Your <span class="gradient-text-primary">Enlightenment</span>
          </h1>
          <p class="text-on-surface-variant text-lg max-w-2xl">
            Finalize your booking for the 1:1 Expert Consultation and unlock professional-grade crypto insights.
          </p>
        </section>

        <!-- Payment Method Toggle -->
        <div class="space-y-6">
          <h3 class="text-xl font-display font-bold">1. Select Payment Method</h3>
          <div class="grid grid-cols-2 gap-4">
            <button
              type="button"
              class="flex items-center justify-center gap-3 p-4 rounded-xl border-2 border-primary-container bg-surface-container-high transition-all min-h-[44px]"
            >
              <!-- payments icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary-container" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
              </svg>
              <span class="font-semibold text-primary">Credit Card</span>
            </button>
            <button
              type="button"
              class="flex items-center justify-center gap-3 p-4 rounded-xl border border-outline-variant bg-surface-container-low hover:bg-surface-container-high transition-all min-h-[44px]"
            >
              <!-- currency_bitcoin icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.06 11.57c.59-.69.94-1.59.94-2.57 0-2.21-1.79-4-4-4V3h-2v2H9V3H7v2H4v2h1c.55 0 1 .45 1 1v8c0 .55-.45 1-1 1H4v2h3v2h2v-2h2v2h2v-2.04c2.23-.3 4-1.99 4-4.1 0-1.15-.47-2.2-1.23-2.96l.29.67zM9 7h4c1.1 0 2 .9 2 2s-.9 2-2 2H9V7zm5 8H9v-4h5c1.1 0 2 .9 2 2s-.9 2-2 2z"/>
              </svg>
              <span class="font-semibold text-on-surface-variant">Crypto Pay</span>
            </button>
          </div>
        </div>

        <!-- Credit Card Form -->
        <form id="checkout-form" class="p-8 rounded-xl bg-surface-container-low space-y-6">
          <div class="grid grid-cols-1 gap-6">
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant ml-1">Cardholder Name</label>
              <input
                type="text"
                placeholder="Johnathan Doe"
                class="w-full bg-surface-container-lowest border-none rounded-lg p-4 focus:ring-2 focus:ring-primary-container/20 text-on-surface placeholder:text-outline-variant"
              />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant ml-1">Card Number</label>
              <div class="relative">
                <input
                  type="text"
                  placeholder="0000 0000 0000 0000"
                  class="w-full bg-surface-container-lowest border-none rounded-lg p-4 focus:ring-2 focus:ring-primary-container/20 text-on-surface placeholder:text-outline-variant"
                />
                <div class="absolute right-4 top-1/2 -translate-y-1/2 flex gap-2">
                  <!-- credit_card icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-sm font-medium text-on-surface-variant ml-1">Expiry Date</label>
                <input
                  type="text"
                  placeholder="MM/YY"
                  class="w-full bg-surface-container-lowest border-none rounded-lg p-4 focus:ring-2 focus:ring-primary-container/20 text-on-surface placeholder:text-outline-variant"
                />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-medium text-on-surface-variant ml-1">CVV</label>
                <input
                  type="password"
                  placeholder="***"
                  class="w-full bg-surface-container-lowest border-none rounded-lg p-4 focus:ring-2 focus:ring-primary-container/20 text-on-surface placeholder:text-outline-variant"
                />
              </div>
            </div>
          </div>

          <!-- Trust Badges -->
          <div class="flex flex-wrap items-center gap-8 py-4 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
            <img
              class="h-6"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAn2Z5olNrTTHLsohm4EfZoM-Tkb42egcX7W-ieOjLrbdfLmtcGsSQmM386vmh6EBXBCHmIaEcPC7CZS3SSC2BOMTYQzWYIXBvtKZcLXgS3564VgR1pmSUWbxualcvNlXUKOY_1FIFlxdgmMLr56TatZMEGrp3mmRUSxaJWQd1g34LclSq0QZz7wE-GyGtHX4ANRzkcEfwMygLWoMIAAAVmAsAelc-Xph5XPjY3i5CmF58Y1va854mLwh1RhI_TiyYnEFtjGJy66Q"
              alt="Visa and Mastercard secure logos"
            />
            <img
              class="h-6"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAQl5dTBckvswdGZDHbuRnJBr9XG-CaencDuyAmE8mPHhHbi2gop3e52gNPIyy2Lw1W5ed7ae6MI9n03RWDkHV2Jk56igKGuEbAkBSFCks-7q565C1ngA1cO_QoliEVWrNpuKV5gkuljFCDsCzPt2ETYl7Fc7bPjmoC-N9v3qkYi3edB-LK15Day999LMu-QHvG28KGO1fwi5T7Fx6ChDHK0DXcpt1s6AQAqQSrqr8eq6IGugFPAhZhbQvWw8SHNZ_GQNVkgMVtbQ"
              alt="Stripe secure payment provider logo"
            />
            <img
              class="h-8"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuC8Vc-pCO8eV3KUAZmm3G9qgwFqtc65AedvwEJW9qAnoFoQ0U2NHzerwi-u8upoc2Fz_CUUyXkkIks3bBo3YmXby65AsriIkBacj301IUxh8lQvfPYfDNttnFNvAkmvmq-5b0z8zBJ_-by7QQPlZWulC-Oqq6NR8mpHJUG_mfklSjic13J-JOk7ngW8oML19wN2VayhoAu4yOE176tVCBaKFz21lmauwW5wueiG1NPOQR60RKWobfdFg4paDKxm_90gmv2ZaHU6UQ"
              alt="McAfee secure trust badge"
            />
            <img
              class="h-6"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCVOpOBPKj-MsRoYqEDjCqW9kDJw20y4mn7Diks_J2phbiYnDTHGzscYNluLTtnYilOK-_5sLiWAbBGraGUEg1ttaFLP1kJ6jnYOT4l1l38cZDAhV2EiSxZB7RRtEnKMsVXsf9_iisX2EVPRfWviV1s_bcbN_OwrIcv4UYKv3sMD4XD2CQzrcDbgfGP0y4_81-5MFT3fhBvkKKCI2jdJ7P07Pg8pmY1hLqaZuUpFzxgtQg6T7tFcIQEv1Q72o3g9PAtplfWl9vquA"
              alt="PCI DSS compliance logo"
            />
          </div>

          <button
            type="submit"
            class="w-full py-5 px-8 rounded-xl gradient-primary text-on-primary-fixed font-display font-extrabold text-xl shadow-xl shadow-primary-container/20 hover:scale-[1.02] active:scale-95 transition-all min-h-[44px]"
          >
            Proceed to Schedule
          </button>

          <p class="text-center text-on-surface-variant text-sm">
            By clicking "Proceed to Schedule", you agree to BitGuru's <a class="underline" href="/terms">Terms of Service</a> and <a class="underline" href="/risk-disclosure">Risk Disclosure</a>.
          </p>
        </form>

      </div>

      <!-- Right Column: Summary & Testimonial -->
      <aside class="lg:col-span-5 space-y-8">

        <!-- Order Summary Card -->
        <div class="glass-panel p-8 rounded-xl border border-outline-variant/10 shadow-2xl">
          <h3 class="text-2xl font-display font-bold mb-6">Order Summary</h3>
          <div class="space-y-6">
            <div class="flex items-start gap-4 pb-6 border-b border-outline-variant/10">
              <div class="w-16 h-16 rounded-lg bg-surface-container-high flex items-center justify-center flex-shrink-0">
                <!-- video_chat icon (filled) -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-secondary-fixed" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12zm-8-7H10v2H8V9H6v6h2v-2h2v2h2V9zm2 6h4c.55 0 1-.45 1-1v-4c0-.55-.45-1-1-1h-4v6zm2-4h2v2h-2v-2z"/>
                </svg>
              </div>
              <div class="flex-1">
                <p class="font-bold text-lg leading-tight">1:1 Crypto Strategy Consultation</p>
                <p class="text-on-surface-variant text-sm mt-1">60-Minute Video Call</p>
                <p class="text-primary-container text-sm mt-1">With Senior Analyst</p>
              </div>
              <div class="text-right">
                <p class="font-bold text-lg">$299</p>
              </div>
            </div>
            <div class="space-y-3 pt-2">
              <div class="flex justify-between text-on-surface-variant">
                <span>Subtotal</span>
                <span>$299.00</span>
              </div>
              <div class="flex justify-between text-on-surface-variant">
                <span>Tax (0%)</span>
                <span>$0.00</span>
              </div>
              <div class="flex justify-between text-2xl font-display font-extrabold pt-4 text-primary">
                <span>Total Due</span>
                <span>$299.00</span>
              </div>
            </div>
          </div>
          <div class="mt-8 p-4 rounded-lg bg-secondary/5 border border-secondary-fixed-dim/20 flex gap-3">
            <!-- stars icon (filled) -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-secondary-fixed-dim flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 16L12 15.45 7.77 18l1.12-4.81-3.73-3.23 4.92-.42L12 5l1.92 4.53 4.92.42-3.73 3.23L16.23 18z"/>
            </svg>
            <p class="text-sm text-secondary">Includes 1-month complimentary access to BitGuru Premium Insider Reports.</p>
          </div>
        </div>

        <!-- Testimonial Bento -->
        <div class="bg-surface-container-low p-8 rounded-xl relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-primary/10 transition-colors"></div>
          <div class="flex gap-1 mb-4">
            <!-- 5 filled stars -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-secondary-fixed" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-secondary-fixed" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-secondary-fixed" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-secondary-fixed" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-secondary-fixed" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          </div>
          <blockquote class="text-lg italic font-medium leading-relaxed mb-6">
            "The consultation wasn't just advice; it was a roadmap. Within three weeks, I restructured my portfolio and avoided the Q3 liquidation event. BitGuru's perspective is worth 10x the booking fee."
          </blockquote>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-container-highest flex-shrink-0">
              <img
                class="w-full h-full object-cover"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuB4rU29sSwQrCyTOCIqGuBD_RtiWyeEQ7iseV1FtLetA47GpPqN3zOMo8Dh7jxu095ps_4_Nfj29c9jWK8ocpf-XEZNN4ju4qCiv5yX_z1O9nvS7l-n-f0c5-ycBSLOnOu8OFUpR0KHJ9_y3aNNuO0CzkNraf1KTOXhWorzqf9KLcB-tgspz18C9yJtngiQDLpSc4w0WRC1J_unkmepH8jiFda4TeE75DNV8m0JfNJe0hVOndKbpDBEV0pF_GevrtGZUME6uqhzpQ"
                alt="Portrait of Mark, a successful crypto trader"
              />
            </div>
            <div>
              <p class="font-bold">Mark S.</p>
              <p class="text-xs text-on-surface-variant uppercase tracking-widest">Portfolio Manager</p>
            </div>
          </div>
        </div>

        <!-- Money Back Guarantee -->
        <div class="flex items-center gap-4 px-4">
          <!-- verified_user icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary-fixed-dim flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
          </svg>
          <div>
            <p class="font-bold text-sm">Satisfaction Guaranteed</p>
            <p class="text-xs text-on-surface-variant">Not happy with your session? We'll refund your fee, no questions asked.</p>
          </div>
        </div>

      </aside>
    </div>
  </main>

  <script>
    document.getElementById("checkout-form")?.addEventListener("submit", (e) => {
      e.preventDefault();
      const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = "Processing...";
      btn.disabled = true;
      setTimeout(() => {
        window.location.href = "/booking-confirmed";
      }, 2000);
    });
  </script>

</BaseLayout>
