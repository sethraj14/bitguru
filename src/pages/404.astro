---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | BitGuru">
  <section class="pt-32 pb-24 px-5 sm:px-8 min-h-[70vh] flex items-center justify-center">
    <div class="text-center max-w-lg">
      <div class="text-8xl font-display font-extrabold gradient-text-primary mb-6">404</div>
      <h1 class="text-3xl font-display font-bold mb-4">Page Not Found</h1>
      <p class="text-on-surface-variant text-lg mb-10 leading-relaxed">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="gradient-primary text-on-primary-fixed px-8 py-4 rounded-xl font-bold text-lg hover:opacity-90 transition-all inline-block">
          Back to Home
        </a>
        <a href="/courses" class="px-8 py-4 rounded-xl border-2 border-primary-container text-primary-container font-bold text-lg hover:bg-primary-container/10 transition-all inline-block">
          Browse Courses
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
