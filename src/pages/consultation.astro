---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="1:1 Crypto Consultation | BitGuru"
  description="Book a 1:1 consultation with expert crypto traders. Get personalized guidance on investments, portfolio management, and trading strategies."
>

  <!-- Hero Section -->
  <header class="relative pt-40 pb-24 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-from)_0%,_transparent_70%)] from-primary-container/10 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="flex flex-col items-center text-center space-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container-high border border-outline-variant/15">
          <!-- verified filled icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-secondary-fixed-dim flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23 12l-2.44-2.79.34-3.69-3.61-.82-1.89-3.2L12 2.96 8.6 1.5 6.71 4.69 3.1 5.5l.34 3.7L1 12l2.44 2.79-.34 3.7 3.61.82 1.89 3.2L12 21.04l3.4 1.46 1.89-3.19 3.61-.82-.34-3.69L23 12zm-12.91 4.72-3.8-3.81 1.48-1.48 2.32 2.33 5.85-5.87 1.48 1.48-7.33 7.35z"/>
          </svg>
          <span class="text-xs font-semibold tracking-widest uppercase text-on-surface-variant">Trusted by 50,000+ learners</span>
        </div>
        <h1 class="font-display text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface max-w-4xl leading-[1.1]">
          Expert Guidance for Your <span class="text-primary-container">Crypto Journey.</span> Book a 1:1 Consultation.
        </h1>
        <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl font-light leading-relaxed">
          Unlock direct access to master traders. Get clarity on investments, portfolio management, and strategies.
        </p>
        <div class="flex flex-col items-center gap-6 mt-4">
          <a href="#book" class="gradient-primary text-on-primary-fixed px-10 py-5 rounded-xl font-display font-extrabold text-lg tracking-tight shadow-[0_0_40px_rgba(0,229,255,0.2)] hover:shadow-[0_0_60px_rgba(0,229,255,0.3)] transition-all active:scale-95 group inline-flex items-center min-h-[44px]">
            Book a 60-Min Call
            <!-- arrow_forward icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
            </svg>
          </a>
          <div class="flex items-center gap-2 text-secondary-fixed-dim animate-pulse">
            <!-- alarm icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 5.72l-4.6-3.86-1.29 1.53 4.6 3.86L22 5.72zM7.88 3.39L6.6 1.86 2 5.71l1.29 1.53 4.59-3.85zM12.5 8H11v6l4.75 2.85.75-1.23-4-2.37V8zM12 4c-4.97 0-9 4.03-9 9s4.02 9 9 9c4.97 0 9-4.03 9-9s-4.03-9-9-9zm0 16c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/>
            </svg>
            <span class="text-sm font-bold tracking-wide uppercase">Limited to 5 slots per week</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Value Propositions (Bento Grid) -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 rounded-xl bg-surface-container-lowest border border-outline-variant/5 hover:bg-surface-container-high transition-colors duration-500">
          <!-- person_search icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary-container mb-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M10 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0-6c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm0 7c-2.67 0-8 1.34-8 4v2h9.5c-.63-.73-1.1-1.61-1.36-2.56L4 17v-.99C4.2 15.29 7.3 15 10 15c.36 0 .73.01 1.09.04-.31-.59-.53-1.23-.63-1.91-.15-.09-.3-.13-.46-.13zm9 2c0-.22-.03-.42-.06-.63l1.14-1 .91 1.58-1.46.83c-.06-.27-.13-.54-.22-.79l-.31.02zm-.35-3.33c-.51-.43-1.15-.67-1.65-.67-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5c.52 0 1-.16 1.4-.44l1.82 1.82 1.06-1.06-1.82-1.83c.28-.4.44-.88.44-1.39 0-.82-.38-1.55-.97-2.04l-.28.61zm-1.65 3.33c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
          </svg>
          <h3 class="font-display text-2xl font-bold mb-4">Personalized guidance</h3>
          <p class="text-on-surface-variant leading-relaxed">No generic advice. We dive deep into your specific financial goals and risk tolerance.</p>
        </div>
        <div class="p-8 rounded-xl bg-surface-container-lowest border border-outline-variant/5 hover:bg-surface-container-high transition-colors duration-500">
          <!-- key icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary-container mb-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>
          </svg>
          <h3 class="font-display text-2xl font-bold mb-4">Direct access</h3>
          <p class="text-on-surface-variant leading-relaxed">Skip the noise. Talk directly to experienced market analysts with years of skin in the game.</p>
        </div>
        <div class="p-8 rounded-xl bg-surface-container-lowest border border-outline-variant/5 hover:bg-surface-container-high transition-colors duration-500">
          <!-- visibility icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary-container mb-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
          </svg>
          <h3 class="font-display text-2xl font-bold mb-4">Market clarity</h3>
          <p class="text-on-surface-variant leading-relaxed">Cut through the volatility. Understand the macro trends and technical setups that actually matter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qualification Sections (Editorial Asymmetry) -->
  <section class="py-32">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-12">
          <div>
            <h2 class="font-display text-4xl font-extrabold tracking-tight mb-8">Who this is <span class="text-primary-container">for</span></h2>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="mt-1 w-6 h-6 rounded-full bg-primary-container/20 flex items-center justify-center flex-shrink-0">
                  <!-- check icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-primary-container" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-lg">Beginners</p>
                  <p class="text-on-surface-variant">Starting from zero and want to avoid expensive mistakes.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-1 w-6 h-6 rounded-full bg-primary-container/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-primary-container" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-lg">Investors</p>
                  <p class="text-on-surface-variant">Looking to optimize their portfolio allocation and long-term storage.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-1 w-6 h-6 rounded-full bg-primary-container/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-primary-container" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-lg">Traders</p>
                  <p class="text-on-surface-variant">Wanting to refine their technical analysis and execution strategies.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
        <div class="glass-panel p-10 rounded-2xl border border-outline-variant/10 shadow-2xl relative overflow-hidden">
          <div class="absolute -top-12 -right-12 w-32 h-32 bg-error/10 blur-3xl rounded-full"></div>
          <h2 class="font-display text-3xl font-extrabold tracking-tight mb-8">Who this is <span class="text-error">NOT</span> for</h2>
          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div class="mt-1 w-6 h-6 rounded-full bg-error/20 flex items-center justify-center flex-shrink-0">
                <!-- close icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-error" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                </svg>
              </div>
              <p class="text-on-surface-variant">Get-rich-quick seekers expecting overnight miracles without effort.</p>
            </li>
            <li class="flex items-start gap-4">
              <div class="mt-1 w-6 h-6 rounded-full bg-error/20 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-error" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                </svg>
              </div>
              <p class="text-on-surface-variant">Gamblers looking for "hot signals" rather than learning methodology.</p>
            </li>
            <li class="flex items-start gap-4">
              <div class="mt-1 w-6 h-6 rounded-full bg-error/20 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-error" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                </svg>
              </div>
              <p class="text-on-surface-variant">People unwilling to take responsibility for their own financial decisions.</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Card (Premium Focus) -->
  <section id="book" class="py-24 relative">
    <div class="max-w-3xl mx-auto px-8">
      <div class="relative group">
        <!-- Decorative Glow -->
        <div class="absolute inset-0 gradient-primary blur-3xl opacity-10 group-hover:opacity-20 transition-opacity rounded-[2rem]"></div>
        <div class="relative bg-surface-container-high rounded-[2rem] p-12 text-center border border-outline-variant/20 shadow-2xl">
          <h3 class="font-display text-2xl font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-4">The Investment</h3>
          <div class="flex items-baseline justify-center gap-2 mb-8">
            <span class="text-6xl md:text-8xl font-black font-display tracking-tighter">$299</span>
            <span class="text-xl text-on-surface-variant">/ session</span>
          </div>
          <div class="space-y-4 mb-10 max-w-md mx-auto">
            <div class="flex items-center gap-3 justify-center text-on-surface">
              <!-- done_all icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-container flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 7l-1.41-1.41-6.34 6.34 1.41 1.41L18 7zm4.24-1.41L11.66 16.17 7.48 12l-1.41 1.41L11.66 19l12-12-1.42-1.41zM.41 13.41L6 19l1.41-1.41L1.83 12 .41 13.41z"/>
              </svg>
              <span>60-Minute Intensive Call</span>
            </div>
            <div class="flex items-center gap-3 justify-center text-on-surface">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-container flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 7l-1.41-1.41-6.34 6.34 1.41 1.41L18 7zm4.24-1.41L11.66 16.17 7.48 12l-1.41 1.41L11.66 19l12-12-1.42-1.41zM.41 13.41L6 19l1.41-1.41L1.83 12 .41 13.41z"/>
              </svg>
              <span>Custom Portfolio Review</span>
            </div>
            <div class="flex items-center gap-3 justify-center text-on-surface">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-container flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 7l-1.41-1.41-6.34 6.34 1.41 1.41L18 7zm4.24-1.41L11.66 16.17 7.48 12l-1.41 1.41L11.66 19l12-12-1.42-1.41zM.41 13.41L6 19l1.41-1.41L1.83 12 .41 13.41z"/>
              </svg>
              <span>PDF Strategy Report Follow-up</span>
            </div>
          </div>
          <a href="/schedule-call" class="w-full gradient-primary text-on-primary-fixed py-5 rounded-xl font-display font-extrabold text-xl tracking-tight transition-all active:scale-95 mb-6 block min-h-[44px] flex items-center justify-center">
            Book a 60-Min Call
          </a>
          <div class="flex flex-col items-center gap-4">
            <div class="inline-flex items-center gap-2 px-6 py-2 rounded-lg bg-secondary-container/10 border border-secondary-fixed-dim/20">
              <!-- workspace_premium filled icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-secondary-fixed-dim flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v3.08C4.45 9.19 6 11.42 6 14c0 2.21-.89 4.21-2.33 5.65C4.4 20.47 5.15 21 6 21h12c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3l1.5 3h3l-2.5 2 1 3L12 13.3 9 15l1-3-2.5-2h3L12 6z"/>
              </svg>
              <span class="font-bold text-secondary-fixed-dim">Clarity guaranteed or next session free</span>
            </div>
            <p class="text-sm text-on-surface-variant">Secure payment via Stripe or Crypto</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Divider -->
  <div class="max-w-7xl mx-auto px-8 py-16">
    <div class="h-px w-full bg-gradient-to-r from-transparent via-outline-variant/30 to-transparent"></div>
  </div>

</BaseLayout>
